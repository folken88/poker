[{"file":"v3_cfe4ef0efb1e22e3f3d4add0.mp3","text":"\"Look at you, throwing around cash like it’s confetti, Josh.","version":"v3","subject":null,"specific":true,"ts":1780638468660},{"file":"v3_a9cd189b97aeff29f36f9819.mp3","text":"\"Big bet, small hand?","version":"v3","subject":null,"specific":false,"ts":1780639680332},{"file":"v3_1873c59b1329a3586b7415a7.mp3","text":"Ooh, look at Miss Fancy Pants throwing around gold like it’s confetti.","version":"v3","subject":null,"specific":false,"ts":1780640050544},{"file":"v3_8cf91bb37b6547be92031a50.mp3","text":"\"Ooh, look at you, Josh — flexing that wealth like a rich bitch.","version":"v3","subject":null,"specific":true,"ts":1780640216257},{"file":"v3_49b5cd3cb65d0b930b2a7c89.mp3","text":"\"What’s the matter, Josh?","version":"v3","subject":null,"specific":true,"ts":1780640470089},{"file":"v3_b6ea09469c6c008a96304e58.mp3","text":"\"Nice try, Josh, but I can smell your fear from here.","version":"v3","subject":null,"specific":true,"ts":1780640502228},{"file":"v3_7946713b3dd57ff3e67bf920.mp3","text":"\"Wow, Josh, what a bold move for a rich bitch—think you can scare us with your shiny chips?","version":"v3","subject":null,"specific":true,"ts":1780640760990},{"file":"v3_a42b08ec1f57db4076674ffc.mp3","text":"\"One eighty-four?","version":"v3","subject":null,"specific":false,"ts":1780642696601},{"file":"v3_54e03ae7e2dbc882c2a9b45b.mp3","text":"\"Big bet, Josh, but are you just flexing or do you actually have something worth a damn?","version":"v3","subject":null,"specific":true,"ts":1780642797054}]