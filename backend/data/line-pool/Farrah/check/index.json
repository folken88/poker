[{"file":"v3_8dc31e5cff9af9388e203eb0.mp3","text":"Check. Let’s see what the rich girl’s hiding.","version":"v3","subject":null,"specific":false,"ts":1780641509724},{"file":"v3_1146f30c57a9249412d8e84a.mp3","text":"\"Free ride? Must be nice, Josh.","version":"v3","subject":null,"specific":true,"ts":1780642118807},{"file":"v3_8b4786662e5f1317d7abc724.mp3","text":"\"Just hanging out, Aunt Judge, while you drown in debt.","version":"v3","subject":null,"specific":false,"ts":1780643474038},{"file":"v3_c4327f957938e34447f03e16.mp3","text":"\"Gonna keep it low-key, unlike some people at this table, huh, Toni?","version":"v3","subject":null,"specific":true,"ts":1780680489929},{"file":"v3_542302787997a7e8a29267f9.mp3","text":"\"Staying in for free, just like your hopes, Toni!","version":"v3","subject":null,"specific":true,"ts":1780680854328},{"file":"v3_6e4ebb03e6c280751a25904d.mp3","text":"\"Just soaking it all in, rich girl.","version":"v3","subject":null,"specific":false,"ts":1780681123092},{"file":"v3_1d504d7e297bb461ffa1ef76.mp3","text":"\"Staying in for free?","version":"v3","subject":null,"specific":false,"ts":1780743454176}]