[{"file":"v3_e3f1f191d5a1ab602b72636d.mp3","text":"Come on, Josh, don’t be shy!","version":"v3","subject":null,"specific":true,"ts":1780639102329},{"file":"v3_deb5f8796df288dfff768a86.mp3","text":"\"Come on, Concetta!","version":"v3","subject":null,"specific":true,"ts":1780642594045},{"file":"v3_9fa8e40999420974e5b7a57d.mp3","text":"\"Come on, Rhyarca, show us that big brain of yours!","version":"v3","subject":null,"specific":true,"ts":1780681105138},{"file":"v3_f8d318203f354093b3dc96fd.mp3","text":"\"Come on, Rhyarca, don’t let the big pot scare you!","version":"v3","subject":null,"specific":true,"ts":1780681143070},{"file":"v3_ed966e62b8a347bd0957e203.mp3","text":"\"C'mon, Aunty Kate, twenty-five gold?","version":"v3","subject":null,"specific":true,"ts":1780681787458},{"file":"v3_99ecfd8421006f1197cb01c7.mp3","text":"\"Come on, Agu!","version":"v3","subject":null,"specific":true,"ts":1780708050343}]