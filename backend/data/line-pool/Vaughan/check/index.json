[{"file":"v3_0b55f4364052dd2b40758205.mp3","text":"\"Checking in while you lot bleed each other dry?","version":"v3","subject":null,"specific":false,"ts":1780722824171},{"file":"v3_e8f7d733b7c747e619145072.mp3","text":"Just soaking it all in, darlings.","version":"v3","subject":null,"specific":false,"ts":1780723693105},{"file":"v3_87f4a09b0c08f8fd4b25a4e1.mp3","text":"Free ride, just like Daramid's debts.","version":"v3","subject":null,"specific":true,"ts":1780724272744},{"file":"v3_44f1d8bdc2d1699adf7ad972.mp3","text":"\"Just keeping my options open, like a true swashbuckler.","version":"v3","subject":null,"specific":false,"ts":1780724499926}]