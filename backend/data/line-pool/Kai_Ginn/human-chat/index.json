[{"file":"v3_8640b126470fc87ed76e2bdc.mp3","text":"\"Chill, Tobis.","version":"v3","subject":null,"specific":false,"ts":1780632846040},{"file":"v3_5403b01cb076df58be6b1795.mp3","text":"\"You good, Mandore?","version":"v3","subject":null,"specific":false,"ts":1780632945363},{"file":"v3_8373eb195a7d808f735466ed.mp3","text":"\"Facts, but I'm still the one with the rizz at this table, fr.","version":"v3","subject":null,"specific":false,"ts":1780633099399},{"file":"v3_b323adf137ec929bb4ad4d79.mp3","text":"Facts, Tobis — I’m just here for the free money.","version":"v3","subject":null,"specific":false,"ts":1780633152979},{"file":"v3_e26a4cf0be756033598270ad.mp3","text":"Stress? Just play better, Mandore.","version":"v3","subject":null,"specific":false,"ts":1780637425771}]