[{"file":"v3_8d215c13fd6258baeb7aab2e.mp3","text":"Come on, Kovira, it's just a small chunk of your remaining coins.","version":"v3","subject":null,"specific":true,"ts":1780707752363},{"file":"v3_98bd11ba32b53ca929d6c39a.mp3","text":"Come on, Kelda, don't leave us hanging!","version":"v3","subject":null,"specific":true,"ts":1780707911411},{"file":"v3_047866e4cfe3b275c8e3e87e.mp3","text":"\"Feeling brave, Rhyarca?","version":"v3","subject":null,"specific":true,"ts":1780708117951},{"file":"v3_ca9acec7133c0b54f6027586.mp3","text":"Kovira, are you really sweating over fifty gold into a pot that fat?","version":"v3","subject":null,"specific":true,"ts":1780708232525}]