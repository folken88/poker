[{"file":"v3_25016163774fe81f80e9f61f.mp3","text":"\"C'mon, Duristan, don’t be shy!","version":"v3","subject":null,"specific":true,"ts":1780722479474},{"file":"v3_8902d6817fcb80588153af0b.mp3","text":"Come on, Duristan, don’t keep us waiting.","version":"v3","subject":null,"specific":true,"ts":1780723075802},{"file":"v3_dd4ff6cea12938a3f0ef76e0.mp3","text":"Chef, you look like a deer in the lantern light.","version":"v3","subject":null,"specific":true,"ts":1780725929971}]