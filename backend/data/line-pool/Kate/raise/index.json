[{"file":"v3_8b37f63976d8c3f745ae5944.mp3","text":"\"Well, look at you, Josh — feeling bold with your little raise.","version":"v3","subject":null,"specific":false,"ts":1780632737799},{"file":"v3_6a76423b59d4b94709d4be75.mp3","text":"Look at Kai over here, swinging that stack like he's got something to prove.","version":"v3","subject":null,"specific":false,"ts":1780632923723},{"file":"v3_0ddb8b47af8eb5a2086f1523.mp3","text":"A bold raise, Kai — trying to buy the pot with that sad stack?","version":"v3","subject":null,"specific":false,"ts":1780633456858},{"file":"v3_d15a4ad5c926dd1652e52f9f.mp3","text":"\"Josh raising to 250 g?","version":"v3","subject":null,"specific":true,"ts":1780635670428},{"file":"v3_7c0078c6dc822995cd8a5f3a.mp3","text":"Look at that, Josh bringing out the big guns.","version":"v3","subject":null,"specific":true,"ts":1780638680145},{"file":"v3_68128b192c262369794bd9e9.mp3","text":"Well, look at that, Farrah’s finally found her spine.","version":"v3","subject":null,"specific":true,"ts":1780681514476}]