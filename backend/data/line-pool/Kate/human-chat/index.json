[{"file":"v3_cea926221feb471b5252c639.mp3","text":"Only when he's trying to impress someone, Mandore.","version":"v3","subject":null,"specific":false,"ts":1780633160632},{"file":"v3_cc1bfc757cd25dbd793af48a.mp3","text":"\"Oh, Gramm, sweetie, I'm not the one sitting on a mountain of chips here—maybe you should take your own advice.","version":"v3","subject":null,"specific":false,"ts":1780633814376},{"file":"v3_50af37a0d6bbb93166f823c9.mp3","text":"Careful now, Mandore — don't let that wit run away from you like your chips.","version":"v3","subject":null,"specific":false,"ts":1780633921512},{"file":"v3_bc4e3e0ed03e27977ddd995b.mp3","text":"Poor, Mandore? You mean financially or just in poker skills?","version":"v3","subject":null,"specific":false,"ts":1780635152745},{"file":"v3_210b0ce592f6b3581be65f8d.mp3","text":"\"Don't worry, Mandore.","version":"v3","subject":null,"specific":false,"ts":1780637751729},{"file":"v3_b62716b70665c5b56b1cf56b.mp3","text":"\"Thanks, Mandore.","version":"v3","subject":null,"specific":true,"ts":1780680961545}]