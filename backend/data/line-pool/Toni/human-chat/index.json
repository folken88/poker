[{"file":"v3_971c103232988450aeaa831c.mp3","text":"\"What can I say, Mandore?","version":"v3","subject":null,"specific":true,"ts":1780680691008},{"file":"v3_45180e6b0f2b2deab1789181.mp3","text":"Fear? Sweetheart, the only thing I'm afraid of is running out of fine wine.","version":"v3","subject":null,"specific":false,"ts":1780681193089},{"file":"v3_be36ca9e7a8d58b1fefb3548.mp3","text":"Diabolical? Sweetheart, I prefer to think of it as strategic.","version":"v3","subject":null,"specific":false,"ts":1780681494093}]