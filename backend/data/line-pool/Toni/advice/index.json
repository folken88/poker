[{"file":"v3_dc100cedd9c98a7ab9bf4718.mp3","text":"Mandore, I can smell the fear from here.","version":"v3","subject":null,"specific":true,"ts":1780681175109},{"file":"v3_4857b9f0222958aecb461b16.mp3","text":"\"Come on, Farrah, don't let the rich girl be scared of fifty gold.","version":"v3","subject":null,"specific":true,"ts":1780682002767},{"file":"v3_025d375a23f6a517d94c5c35.mp3","text":"Tick tock, Farrah.","version":"v3","subject":null,"specific":true,"ts":1780682151925},{"file":"v3_cd965210dc40e3205480e36a.mp3","text":"Chef, darling, it’s fifty gold.","version":"v3","subject":null,"specific":true,"ts":1780724025285},{"file":"v3_6a980b5d8cfefc2ab156bec2.mp3","text":"Vaughan, darling, do you need a moment to count your pennies, or are you just hoping for a miracle?","version":"v3","subject":null,"specific":true,"ts":1780724538960},{"file":"v3_ecf80aee86f273b53dff0b4e.mp3","text":"Come on, Daramid, are you waiting for a personal invitation?","version":"v3","subject":null,"specific":true,"ts":1780724559959}]