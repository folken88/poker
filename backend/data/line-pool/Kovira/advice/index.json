[{"file":"v3_0f38fbd3a61f1fbeaca2996a.mp3","text":"Tick-tock, Concetta!","version":"v3","subject":null,"specific":true,"ts":1780655726926},{"file":"v3_8e708744508a66087a8cf451.mp3","text":"Ooh, Gaspar, darling, do you need a map to find your courage?","version":"v3","subject":null,"specific":true,"ts":1780707803278},{"file":"v3_303644d3edee6284940fe468.mp3","text":"Toni, sweetie, you can afford that call!","version":"v3","subject":null,"specific":true,"ts":1780722666580},{"file":"v3_5e4a89954b4a0d699b0bf783.mp3","text":"Rissa, darling, you're not thinking of folding, are you?","version":"v3","subject":null,"specific":true,"ts":1780722787187},{"file":"v3_2ef94ed85d2e77cfcf8ca30c.mp3","text":"Ooh, Chef, feeling bold or just confused?","version":"v3","subject":null,"specific":true,"ts":1780724080260},{"file":"v3_8c5455eb3dfc4b739ae67cda.mp3","text":"Ooh, Duristan, you sure about that?","version":"v3","subject":null,"specific":true,"ts":1780724690114},{"file":"v3_aa022766a4907e090914931a.mp3","text":"Tamsin, you sure you can afford that fifty?","version":"v3","subject":null,"specific":true,"ts":1780724767276},{"file":"v3_581b5a0b1c676fb9f993f531.mp3","text":"Come on, Dinvaya, you can't just stare at those chips like they're a riddle!","version":"v3","subject":null,"specific":true,"ts":1780725060742},{"file":"v3_418818e009491f17ee47bd5e.mp3","text":"Rissa, darling, what are you waiting for?","version":"v3","subject":null,"specific":true,"ts":1780725802377}]