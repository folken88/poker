[{"file":"v3_67cd7f1792af8fa7df385718.mp3","text":"\"That’s a filthy blow!","version":"v3","subject":"Ghast","specific":false,"ts":1780600455583},{"file":"v3_663be7ed8f04268819d1839a.mp3","text":"\"You think that tickles?","version":"v3","subject":"Monk","specific":false,"ts":1780600777157},{"file":"v3_7b94fe84786a3f7e748e1a32.mp3","text":"Keep swinging, but next time, aim for the brain!","version":"v3","subject":"Zombie","specific":false,"ts":1780600826530},{"file":"v3_79a97699455493e3b94ea5c9.mp3","text":"\"That’s it! You just signed your own death warrant!","version":"v3","subject":"Zombie","specific":false,"ts":1780601149001},{"file":"v3_f12c68eac1ac59279adb0743.mp3","text":"Pathetic! You call that a bite?","version":"v3","subject":"Giant Centipede","specific":false,"ts":1780605662556},{"file":"v3_332a5655685d73c1c17bbdd6.mp3","text":"\"You’ll pay for that, you nimble pest!","version":"v3","subject":"Monk","specific":false,"ts":1780645388176},{"file":"v3_0262e7d73aaccbebe6b57211.mp3","text":"\"Is that all you've got?","version":"v3","subject":"Monk","specific":false,"ts":1780645415214},{"file":"v3_3ecddf8e0f4f839d9b7ef50d.mp3","text":"\"You think a little pain will stop me?","version":"v3","subject":"Boss: Dire Bear","specific":false,"ts":1780660402209},{"file":"v3_6de8404c8f4286a403a609e9.mp3","text":"\"Is that all you've got, feather-brain?","version":"v3","subject":"Harpy","specific":false,"ts":1780660756829},{"file":"v3_0d0be0df3f9ffa4188a91b7a.mp3","text":"\"You think that stings?","version":"v3","subject":"Gargoyle","specific":false,"ts":1780756096127},{"file":"v3_6374287514ef588da21b9b10.mp3","text":"\"You’ll pay for that, beast!","version":"v3","subject":"Chimera","specific":false,"ts":1780778583791}]