[{"file":"v3_202e0a9bb4adc0d707905fa1.mp3","text":"\"The wicked shall not weave their webs here!","version":"v3","subject":"Giant Spider","specific":false,"ts":1780605878420},{"file":"v3_62e18e269ae321fba9467253.mp3","text":"\"Pharasma cleanses the wicked!","version":"v3","subject":"Skeleton","specific":false,"ts":1780644620167},{"file":"v3_408095e73f3689d755d2ac7b.mp3","text":"\"By Pharasma's grace, your soul finds peace in the dust!","version":"v3","subject":"Ghoul","specific":false,"ts":1780644663897},{"file":"v3_ab9e7d6b8c8f3eae105da3a0.mp3","text":"\"The wicked fall like trees in the tempest!","version":"v3","subject":"Ogre","specific":false,"ts":1780660124619},{"file":"v3_4b20f6a2a16ac9e364a8f5c5.mp3","text":"\"Pharasma weighs the bones of the wicked!","version":"v3","subject":"Goblin","specific":false,"ts":1780700166443},{"file":"v3_904a9d50f09c927eaaf2b14f.mp3","text":"\"The dead shall not rise again!","version":"v3","subject":"Zombie","specific":false,"ts":1780700300205},{"file":"v3_666fea71474bb6137f6ce7b3.mp3","text":"\"Pharasma claims the soul of the wretched!","version":"v3","subject":"Zombie","specific":false,"ts":1780700388587},{"file":"v3_60a8cf5dd689b45a3eff7805.mp3","text":"\"Pharasma claims the wicked!","version":"v3","subject":"Blood Caimon","specific":false,"ts":1780779755348}]