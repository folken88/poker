[{"file":"v3_7efdf01ebb217cf97586df7f.mp3","text":"Look at the big man, weighing his options!","version":"v3","subject":null,"specific":false,"ts":1780631396015},{"file":"v3_d5859a5bf4c40e9dfbced0cc.mp3","text":"Ooh, Chef’s in the hot seat!","version":"v3","subject":null,"specific":true,"ts":1780723448008},{"file":"v3_f8e47a7bfac0ab5e86c7a55a.mp3","text":"Oh, Chef, are you really going to let a mere fifty gold stop you?","version":"v3","subject":null,"specific":true,"ts":1780723544103},{"file":"v3_a91377b08a8c5a1a2ef25a53.mp3","text":"900 gp into 900 gp?","version":"v3","subject":null,"specific":true,"ts":1780723675062},{"file":"v3_9d7467872d58b65c3db045d5.mp3","text":"Come on, Rissa!","version":"v3","subject":null,"specific":true,"ts":1780725997427},{"file":"v3_e64c3c29422f06eb1325a246.mp3","text":"Come on, Daramid, that's a mere trifle!","version":"v3","subject":null,"specific":true,"ts":1780726195988},{"file":"v3_80123348c262fd05ec4a79c0.mp3","text":"I can smell the fear, Daramid!","version":"v3","subject":null,"specific":true,"ts":1780726358837}]