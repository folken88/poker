[{"file":"v3_36a9bdb5f1dba3b0f02340b9.mp3","text":"\"I will not be silenced!","version":"v3","subject":"Whispering Cultist","specific":false,"ts":1780601104466},{"file":"v3_65d4d51dda01915064f0b141.mp3","text":"\"Inefficient strike. You will need to adjust your tactics.","version":"v3","subject":"Goblin Rogue","specific":false,"ts":1780636493333},{"file":"v3_0d8e7415e428fade80b60fe1.mp3","text":"\"Incoherent babble cannot deter logic!","version":"v3","subject":"Gibbering Mouther","specific":false,"ts":1780659558602},{"file":"v3_d33eb415ce83e268ef72f31b.mp3","text":"Your technique is flawed; your strikes lack precision.","version":"v3","subject":"Monk","specific":false,"ts":1780660037464}]