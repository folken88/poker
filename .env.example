# Copy to .env (which is gitignored) and fill in real values.
# The container reads these via docker-compose interpolation.
#
# ELEVENLABS_API_KEY — 11labs TTS for AI character banter. Used
# server-side only. If unset, the banter feature degrades gracefully
# to text-only chat (current behaviour pre-feature).
ELEVENLABS_API_KEY=
